{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repetita.gravity/schemas/family-transaction.schema.json",
  "title": "Isolated recurrence-family transaction",
  "type": "object",
  "additionalProperties": false,
  "required": ["transaction_id", "family_id", "base_document_hash", "state", "centre", "donors", "receiver", "changed_unit_ids", "verification"],
  "properties": {
    "transaction_id": {"type": "string"},
    "family_id": {"type": "string"},
    "base_document_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "state": {"enum": ["planned", "proposed", "verified", "committed", "rolled_back", "human_review"]},
    "centre": {"type": "string"},
    "donors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["unit_id", "original_text", "duplicated_payload", "unique_residual_payload", "local_function", "hard_anchors", "proposed_repair"],
        "properties": {
          "unit_id": {"type": "string"},
          "original_text": {"type": "string"},
          "duplicated_payload": {"type": "array", "items": {"type": "string"}},
          "unique_residual_payload": {"type": "array", "items": {"type": "string"}},
          "local_function": {"type": "string"},
          "hard_anchors": {"type": "array", "items": {"type": "string"}},
          "proposed_repair": {"type": "string"}
        }
      }
    },
    "receiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["original_text", "incoming_payload", "proposed_text", "provenance"],
      "properties": {
        "original_text": {"type": "string"},
        "incoming_payload": {"type": "array", "items": {"type": "string"}},
        "proposed_text": {"type": "string"},
        "provenance": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_unit_id", "target_span"],
            "properties": {
              "source_unit_id": {"type": "string"},
              "target_span": {"type": "string"}
            }
          }
        }
      }
    },
    "changed_unit_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ledger_reconciled", "anchors_preserved", "scope_isolated", "cross_references_resolve", "new_duplication_absent", "semantic_adjudication", "failures"],
      "properties": {
        "ledger_reconciled": {"type": "boolean"},
        "anchors_preserved": {"type": "boolean"},
        "scope_isolated": {"type": "boolean"},
        "cross_references_resolve": {"type": "boolean"},
        "new_duplication_absent": {"type": "boolean"},
        "semantic_adjudication": {"enum": ["passed", "failed", "human_review"]},
        "failures": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}

